  "keyFeatures": [
    "Entity-level diff showing added, modified, deleted, and renamed functions/classes instead of line-level changes",
    "21 programming languages supported via native tree-sitter parsers",
    "Structural hashing to distinguish cosmetic (whitespace/formatting) from real logic changes",
    "Entity-level blame: who last modified each function, not each line",
    "Cross-file dependency graph via call/reference analysis",
    "Transitive impact analysis using BFS through the dependency graph",
    "JSON output for AI agents and CI pipeline integration",
    "Stdin mode for non-git usage and streaming file diffs",
    "Works as a drop-in replacement for git diff"
  ],
  "publicApiSurface": [
    "sem diff",
    "sem diff --staged",
    "sem diff --commit <ref>",
    "sem diff --from <ref> --to <ref>",
    "sem diff --format json|plain|markdown",
    "sem diff --stdin --format json",
    "sem diff --file-exts .py .rs",
    "sem blame <file>",
    "sem blame <file> --json",
    "sem graph",
    "sem graph --entity <name>",
    "sem graph --format json",
    "sem impact <entity>",
    "sem impact <entity> --json",
    "sem log <entity>",
    "sem log <entity> --verbose",
    "sem-core (Rust library crate)"
  ]
